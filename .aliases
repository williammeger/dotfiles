# aliases for .bash_profile

# easier navigation
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."

# ls mods
alias ls="ls -GFh"
alias ll="ls -al"

# cd, clear and such
alias cc="clear"
alias -- -="cd -"

# better PATH readability
alias path="tr ':' '\n' <<< '$PATH'"

# thanks to paul irish for these
alias chmox='chmod -x'

alias where=which  
alias abd=adb # typos

alias vi="/usr/local/bin/vim"

# dotfiles under git no more symlinks !
# https://news.ycombinator.com/item?id=11071754
# https://developer.atlassian.com/blog/2016/02/best-way-to-store-dotfiles-git-bare-repo/
alias config="/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME"

# android tools
# needs proper android env configuration in .extras
alias avds="emulator -list-avds"
