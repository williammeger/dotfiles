#!/usr/bin/env bash
# tmux-pane-context — Renders rich context for a tmux pane by matching
# its working directory to the most recent Copilot session in the session store.
#
# Usage: tmux-pane-context <session:window.pane>
# Output: ANSI-colored text for fzf --ansi preview

set -euo pipefail

TARGET="${1:?Usage: tmux-pane-context <target>}"
DB="$HOME/.copilot/session-store.db"

# ─── Theme (from tmux conf — dark foregrounds for light terminal bg) ─────────
# Palette: 214 (orange accent), 232 (black), 238 (dark gray), 246 (mid gray)
# Semantic: green (ANSI 32, matches git branch in prompt), 130 (amber — remaining)
C_ORANGE=$'\033[38;5;214m'  # colour214 — accent
C_PRIMARY=$'\033[38;5;232m' # colour232 — near-black (prominent: titles, branches)
C_TEXT=$'\033[38;5;238m'    # colour238 — dark gray (standard text)
C_MUTED=$'\033[38;5;246m'   # colour246 — mid gray (less prominent: paths, meta)
C_DONE=$'\033[32m'          # standard ANSI green — matches git branch in prompt
C_NEXT=$'\033[38;5;130m'    # amber — remaining/next steps
C_BOLD=$'\033[1m'
C_RESET=$'\033[0m'

# ─── Pane metadata ───────────────────────────────────────────────────────────
pane_title=$(tmux display-message -t "$TARGET" -p "#{pane_title}" 2>/dev/null || echo "")
pane_cmd=$(tmux display-message -t "$TARGET" -p "#{pane_current_command}" 2>/dev/null || echo "")
pane_path=$(tmux display-message -t "$TARGET" -p "#{pane_current_path}" 2>/dev/null || echo "")

# ─── Git / worktree info ─────────────────────────────────────────────────────
git_branch=""
git_root=""
worktree_name=""

if [[ -n "$pane_path" ]] && git -C "$pane_path" rev-parse --is-inside-work-tree &>/dev/null; then
    git_branch=$(git -C "$pane_path" branch --show-current 2>/dev/null || echo "")
    git_root=$(git -C "$pane_path" rev-parse --show-toplevel 2>/dev/null || echo "")

    # Detect worktree: path contains .worktrees/
    if [[ "$git_root" == *".worktrees/"* ]]; then
        worktree_name=$(basename "$git_root")
    fi
fi

# ─── Derive display name ─────────────────────────────────────────────────────
display_name=""
if [[ -n "$git_branch" ]]; then
    display_name="$git_branch"
elif [[ -n "$pane_path" ]]; then
    display_name="${pane_path/#$HOME/~}"
    # Show only last 2 segments for brevity
    display_name=$(echo "$display_name" | rev | cut -d/ -f1-2 | rev)
fi

# ─── Render header ───────────────────────────────────────────────────────────
echo "${C_MUTED}┌──────────────────────────────────────────────────────${C_RESET}"
echo "${C_MUTED}│${C_RESET} ${C_ORANGE}${C_BOLD}$TARGET${C_RESET}"

if [[ -n "$pane_title" && "$pane_title" != "$pane_cmd" ]]; then
    echo "${C_MUTED}│${C_RESET} ${C_PRIMARY}$pane_title${C_RESET}"
fi

echo "${C_MUTED}├──────────────────────────────────────────────────────${C_RESET}"

# Branch line
if [[ -n "$git_branch" ]]; then
    local_label="${C_PRIMARY}${C_BOLD} $git_branch${C_RESET}"
    if [[ -n "$worktree_name" ]]; then
        local_label+="  ${C_MUTED}(worktree)${C_RESET}"
    fi
    echo "${C_MUTED}│${C_RESET} $local_label"
fi

# Path + command
short_path=$(echo "$pane_path" | sed "s|$HOME|~|")
echo "${C_MUTED}│${C_RESET} ${C_MUTED}${pane_cmd} @ ${short_path}${C_RESET}"
echo "${C_MUTED}└──────────────────────────────────────────────────────${C_RESET}"
echo ""

# ─── Session store lookup ────────────────────────────────────────────────────
if [[ ! -f "$DB" ]]; then
    echo "${C_MUTED}  (no session store)${C_RESET}"
    exit 0
fi

PANE_PATH="$pane_path" C_ORANGE="$C_ORANGE" C_MUTED="$C_MUTED" C_PRIMARY="$C_PRIMARY" C_TEXT="$C_TEXT" C_DONE="$C_DONE" C_NEXT="$C_NEXT" C_BOLD="$C_BOLD" C_RESET="$C_RESET" python3 << 'PYEOF'
import sqlite3
import os
import sys
import subprocess
import re

db_path = os.path.expanduser("~/.copilot/session-store.db")
pane_path = os.environ.get("PANE_PATH", "")

# ANSI from env
O = os.environ.get("C_ORANGE", "")
M = os.environ.get("C_MUTED", "")
P = os.environ.get("C_PRIMARY", "")
T = os.environ.get("C_TEXT", "")
G = os.environ.get("C_DONE", "")
N = os.environ.get("C_NEXT", "")
BD = os.environ.get("C_BOLD", "")
R = os.environ.get("C_RESET", "")

WIDTH = 80

def sentences(text, color, label="", label_color=""):
    """Render text one sentence per line, in consistent color."""
    # Strip any embedded ANSI escapes from raw data
    text = re.sub(r'\x1b\[[0-9;]*m', '', text)
    clean = " ".join(text.replace("`", "").replace("**", "").split())
    # Split on sentence boundaries (period/!/? followed by space and uppercase)
    parts = re.split(r'(?<=[.!?])\s+(?=[A-Z\[])', clean)
    if label:
        lc = label_color or color
        print(f"  {lc}{BD}{label}{R}")
    for s in parts:
        s = s.strip().lstrip("- •*[]x0-9.) ")
        if s:
            # Wrap long sentences at WIDTH
            while len(s) > WIDTH:
                cut = s.rfind(" ", 0, WIDTH)
                if cut == -1:
                    cut = WIDTH
                print(f"  {color}{s[:cut]}{R}")
                s = s[cut:].lstrip()
            if s:
                print(f"  {color}{s}{R}")

def git_log(path, count=3):
    """Get recent git commits for the path."""
    try:
        result = subprocess.run(
            ["git", "--no-pager", "-C", path, "log", "--oneline", f"-{count}"],
            capture_output=True, text=True, timeout=2
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip().split("\n")
    except Exception:
        pass
    return []

# ─── Git history ──────────────────────────────────────────────────────────────
commits = git_log(pane_path) if pane_path else []
if commits:
    print(f"  {M}recent commits{R}")
    for c in commits:
        print(f"  {T}{c}{R}")
    print("")

# ─── Session store ────────────────────────────────────────────────────────────
if not pane_path or not os.path.exists(db_path):
    if not commits:
        print(f"  {M}(no session data){R}")
    print("")
    print(f"  {M}{'─' * 50}{R}")
    print(f"  {M}shift-↑↓ scroll · shift-←→ page · esc close{R}")
    sys.exit(0)

conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row

# Prefer sessions with checkpoints, then fall back to most recent
session = conn.execute("""
    SELECT s.id, s.summary, s.cwd, s.updated_at,
           (SELECT COUNT(*) FROM checkpoints c WHERE c.session_id = s.id) as cp_count
    FROM sessions s WHERE s.cwd = ?
    ORDER BY cp_count DESC, s.updated_at DESC LIMIT 1
""", (pane_path,)).fetchone()

# Prefix match (worktrees, subdirs)
if not session:
    session = conn.execute("""
        SELECT s.id, s.summary, s.cwd, s.updated_at,
               (SELECT COUNT(*) FROM checkpoints c WHERE c.session_id = s.id) as cp_count
        FROM sessions s
        WHERE ? LIKE s.cwd || '%' OR s.cwd LIKE ? || '%'
        ORDER BY cp_count DESC, s.updated_at DESC LIMIT 1
    """, (pane_path, pane_path)).fetchone()

if not session:
    print(f"  {M}(no Copilot session for this directory){R}")
    print("")
    print(f"  {M}{'─' * 50}{R}")
    print(f"  {M}shift-↑↓ scroll · shift-←→ page · esc close{R}")
    sys.exit(0)

session_id = session["id"]
summary = session["summary"] or "(no summary)"
updated = session["updated_at"] or ""

print(f"  {P}{BD}{summary}{R}")
print(f"  {M}{updated[:19].replace('T', ' ')}{R}")
print("")

# Latest checkpoint
cp = conn.execute("""
    SELECT title, overview, work_done, next_steps
    FROM checkpoints WHERE session_id = ?
    ORDER BY checkpoint_number DESC LIMIT 1
""", (session_id,)).fetchone()

if cp:
    if cp["title"]:
        print(f"  {M}── {cp['title']} ──{R}")
        print("")

    if cp["overview"]:
        sentences(cp["overview"], T)
        print("")

    if cp["work_done"]:
        sentences(cp["work_done"], T, label="✓ Done", label_color=G)
        print("")

    if cp["next_steps"]:
        sentences(cp["next_steps"], T, label="→ Next", label_color=N)
else:
    turn = conn.execute("""
        SELECT user_message FROM turns
        WHERE session_id = ? ORDER BY turn_index ASC LIMIT 1
    """, (session_id,)).fetchone()
    if turn and turn["user_message"]:
        sentences(turn["user_message"][:400], T, label="ask")

conn.close()

# Help — always visible at the bottom
print("")
print(f"  {M}{'─' * 50}{R}")
print(f"  {M}shift-↑↓ scroll · shift-←→ page · esc close{R}")
PYEOF
