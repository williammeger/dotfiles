#!/usr/bin/env bash
# tmux-pane-context вҖ” Renders rich context for a tmux pane by matching
# its working directory to the most recent Copilot session in the session store.
#
# Usage: tmux-pane-context <session:window.pane>
# Output: ANSI-colored text for fzf --ansi preview

set -euo pipefail

TARGET="${1:?Usage: tmux-pane-context <target>}"
DB="$HOME/.copilot/session-store.db"

# в”Җв”Җв”Җ Theme (from tmux conf вҖ” dark foregrounds for light terminal bg) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Palette: 214 (orange accent), 232 (black), 238 (dark gray), 246 (mid gray)
# Semantic: green (ANSI 32, matches git branch in prompt), 130 (amber вҖ” remaining)
C_ORANGE=$'\033[38;5;214m'  # colour214 вҖ” accent
C_PRIMARY=$'\033[38;5;232m' # colour232 вҖ” near-black (prominent: titles, branches)
C_TEXT=$'\033[38;5;238m'    # colour238 вҖ” dark gray (standard text)
C_MUTED=$'\033[38;5;246m'   # colour246 вҖ” mid gray (less prominent: paths, meta)
C_DONE=$'\033[32m'          # standard ANSI green вҖ” matches git branch in prompt
C_NEXT=$'\033[38;5;130m'    # amber вҖ” remaining/next steps
C_BOLD=$'\033[1m'
C_RESET=$'\033[0m'

# в”Җв”Җв”Җ Pane metadata в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
pane_title=$(tmux display-message -t "$TARGET" -p "#{pane_title}" 2>/dev/null || echo "")
pane_cmd=$(tmux display-message -t "$TARGET" -p "#{pane_current_command}" 2>/dev/null || echo "")
pane_path=$(tmux display-message -t "$TARGET" -p "#{pane_current_path}" 2>/dev/null || echo "")

# в”Җв”Җв”Җ Git / worktree info в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
git_branch=""
git_root=""
worktree_name=""

if [[ -n "$pane_path" ]] && git -C "$pane_path" rev-parse --is-inside-work-tree &>/dev/null; then
    git_branch=$(git -C "$pane_path" branch --show-current 2>/dev/null || echo "")
    git_root=$(git -C "$pane_path" rev-parse --show-toplevel 2>/dev/null || echo "")

    # Detect worktree: path contains .worktrees/
    if [[ "$git_root" == *".worktrees/"* ]]; then
        worktree_name=$(basename "$git_root")
    fi
fi

# в”Җв”Җв”Җ Derive display name в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
display_name=""
if [[ -n "$git_branch" ]]; then
    display_name="$git_branch"
elif [[ -n "$pane_path" ]]; then
    display_name="${pane_path/#$HOME/~}"
    # Show only last 2 segments for brevity
    display_name=$(echo "$display_name" | rev | cut -d/ -f1-2 | rev)
fi

# в”Җв”Җв”Җ Render header в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo "${C_MUTED}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${C_RESET}"
echo "${C_MUTED}в”Ӯ${C_RESET} ${C_ORANGE}${C_BOLD}$TARGET${C_RESET}"

if [[ -n "$pane_title" && "$pane_title" != "$pane_cmd" ]]; then
    echo "${C_MUTED}в”Ӯ${C_RESET} ${C_PRIMARY}$pane_title${C_RESET}"
fi

echo "${C_MUTED}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${C_RESET}"

# Branch line
if [[ -n "$git_branch" ]]; then
    local_label="${C_PRIMARY}${C_BOLD} $git_branch${C_RESET}"
    if [[ -n "$worktree_name" ]]; then
        local_label+="  ${C_MUTED}(worktree)${C_RESET}"
    fi
    echo "${C_MUTED}в”Ӯ${C_RESET} $local_label"
fi

# Path + command
short_path=$(echo "$pane_path" | sed "s|$HOME|~|")
echo "${C_MUTED}в”Ӯ${C_RESET} ${C_MUTED}${pane_cmd} @ ${short_path}${C_RESET}"
echo "${C_MUTED}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${C_RESET}"
echo ""

# в”Җв”Җв”Җ Session store lookup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [[ ! -f "$DB" ]]; then
    echo "${C_MUTED}  (no session store)${C_RESET}"
    exit 0
fi

PANE_PATH="$pane_path" C_ORANGE="$C_ORANGE" C_MUTED="$C_MUTED" C_PRIMARY="$C_PRIMARY" C_TEXT="$C_TEXT" C_DONE="$C_DONE" C_NEXT="$C_NEXT" C_BOLD="$C_BOLD" C_RESET="$C_RESET" python3 << 'PYEOF'
import sqlite3
import os
import sys
import textwrap

db_path = os.path.expanduser("~/.copilot/session-store.db")
pane_path = os.environ.get("PANE_PATH", "")

# ANSI from env
O = os.environ.get("C_ORANGE", "")
M = os.environ.get("C_MUTED", "")
P = os.environ.get("C_PRIMARY", "")
T = os.environ.get("C_TEXT", "")
G = os.environ.get("C_DONE", "")
N = os.environ.get("C_NEXT", "")
BD = os.environ.get("C_BOLD", "")
R = os.environ.get("C_RESET", "")

WIDTH = 52

def prose(text, color, indent="  "):
    """Render text as wrapped prose with consistent color."""
    clean = " ".join(text.replace("`", "").split())
    for line in textwrap.wrap(clean, width=WIDTH):
        print(f"{indent}{color}{line}{R}")

if not pane_path or not os.path.exists(db_path):
    print(f"  {M}(no matching session data){R}")
    sys.exit(0)

conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row

# Prefer sessions with checkpoints, then fall back to most recent
session = conn.execute("""
    SELECT s.id, s.summary, s.cwd, s.updated_at,
           (SELECT COUNT(*) FROM checkpoints c WHERE c.session_id = s.id) as cp_count
    FROM sessions s WHERE s.cwd = ?
    ORDER BY cp_count DESC, s.updated_at DESC LIMIT 1
""", (pane_path,)).fetchone()

# Prefix match (worktrees, subdirs)
if not session:
    session = conn.execute("""
        SELECT s.id, s.summary, s.cwd, s.updated_at,
               (SELECT COUNT(*) FROM checkpoints c WHERE c.session_id = s.id) as cp_count
        FROM sessions s
        WHERE ? LIKE s.cwd || '%' OR s.cwd LIKE ? || '%'
        ORDER BY cp_count DESC, s.updated_at DESC LIMIT 1
    """, (pane_path, pane_path)).fetchone()

if not session:
    print(f"  {M}(no Copilot session for this directory){R}")
    print("")
    print(f"  {M}{'в”Җ' * WIDTH}{R}")
    print(f"  {M}shift-вҶ‘вҶ“ scroll В· shift-вҶҗвҶ’ page В· esc close{R}")
    sys.exit(0)

session_id = session["id"]
summary = session["summary"] or "(no summary)"
updated = session["updated_at"] or ""

print(f"  {O}{BD}{summary}{R}")
print(f"  {M}{updated[:19].replace('T', ' ')}{R}")
print("")

# Latest checkpoint
cp = conn.execute("""
    SELECT title, overview, work_done, next_steps
    FROM checkpoints WHERE session_id = ?
    ORDER BY checkpoint_number DESC LIMIT 1
""", (session_id,)).fetchone()

if cp:
    if cp["title"]:
        print(f"  {M}в”Җв”Җ{R} {P}{BD}{cp['title']}{R} {M}в”Җв”Җ{R}")
        print("")

    if cp["overview"]:
        prose(cp["overview"], T)
        print("")

    if cp["work_done"]:
        print(f"  {G}{BD}вң“ Done{R}")
        prose(cp["work_done"], G)
        print("")

    if cp["next_steps"]:
        print(f"  {N}{BD}вҶ’ Next{R}")
        prose(cp["next_steps"], N)
else:
    turn = conn.execute("""
        SELECT user_message FROM turns
        WHERE session_id = ? ORDER BY turn_index ASC LIMIT 1
    """, (session_id,)).fetchone()
    if turn and turn["user_message"]:
        print(f"  {M}ASK:{R}")
        prose(turn["user_message"][:300], T)

conn.close()

# Help вҖ” always visible at the bottom
print("")
print(f"  {M}{'в”Җ' * WIDTH}{R}")
print(f"  {M}shift-вҶ‘вҶ“ scroll В· shift-вҶҗвҶ’ page В· esc close{R}")
PYEOF
