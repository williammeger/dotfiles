#!/usr/bin/env bash
# tmux-mgr-fzf — FZF-powered tmux navigator
# Single fzf instance with reload-based view switching (sessions/windows/panes).
# Inspired by sesh, tmux-sessionx, tmux-agent-status patterns.

set -euo pipefail

SKILL_DIR="${TMUX_MGR_DIR:-$HOME/.copilot/skills/tmux-sessions}"
CTX_BIN="$SKILL_DIR/bin/tmux-pane-context"
MD_BIN="$SKILL_DIR/bin/tmux-pane-context-md"

# ─── Theme (from tmux conf: 214, 232, 238, 246) ─────────────────────────────
C_ORANGE=$'\033[38;5;214m'
C_PRIMARY=$'\033[38;5;232m'
C_TEXT=$'\033[38;5;238m'
C_MUTED=$'\033[38;5;246m'
C_BOLD=$'\033[1m'
C_RESET=$'\033[0m'

FZF_THEME="--color=fg+:232,bg+:252,hl:214,hl+:214,pointer:214,prompt:214,header:238,border:246,info:246"

# ─── List builders ───────────────────────────────────────────────────────────

_list_sessions() {
    tmux list-sessions -F "#{session_name}|#{session_windows}|#{session_attached}" 2>/dev/null | \
    while IFS='|' read -r name wins attached; do
        local icon="○"
        [[ "$attached" == "1" ]] && icon="●"
        printf "${C_ORANGE}%s${C_RESET}  ${C_TEXT}%s win${C_RESET}  ${C_MUTED}%s${C_RESET}\n" \
            "$name" "$wins" "$icon"
    done
}

_list_windows() {
    tmux list-windows -a -F "#{session_name}:#{window_index}|#{window_name}|#{window_panes}|#{pane_current_path}" 2>/dev/null | \
    while IFS='|' read -r target wname panes path; do
        local label
        label=$(_short_label "$path")
        printf "${C_ORANGE}%-10s${C_RESET} ${C_PRIMARY}%-28s${C_RESET} ${C_MUTED}%s pane%s${C_RESET}\n" \
            "$target" "${label:0:28}" "$panes" "$([[ "$panes" != "1" ]] && echo "s")"
    done
}

_list_panes() {
    tmux list-panes -a -F "#{session_name}:#{window_index}.#{pane_index}|#{pane_current_command}|#{pane_current_path}" 2>/dev/null | \
    while IFS='|' read -r target cmd path; do
        local label
        label=$(_short_label "$path")
        printf "${C_ORANGE}%-10s${C_RESET} ${C_PRIMARY}%-28s${C_RESET} ${C_MUTED}%s${C_RESET}\n" \
            "$target" "${label:0:28}" "$cmd"
    done
}

_short_label() {
    local path="$1"
    if git -C "$path" rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
        local branch
        branch=$(git -C "$path" branch --show-current 2>/dev/null || echo "")
        if [[ -n "$branch" ]]; then
            local root
            root=$(git -C "$path" rev-parse --show-toplevel 2>/dev/null || echo "")
            if [[ "$root" == *".worktrees/"* ]]; then
                echo "◆ $branch"
            else
                echo " $branch"
            fi
            return
        fi
    fi
    echo "${path/#$HOME/\~}" | rev | cut -d/ -f1-2 | rev
}

# ─── Main navigator ─────────────────────────────────────────────────────────

do_navigate() {
    local choice
    choice=$(_list_panes | \
        fzf --ansi --height=100% --layout=reverse --border=rounded $FZF_THEME \
            --prompt="❯ " \
            --header=$'ctrl-s sessions · ctrl-w windows · ctrl-p panes · ctrl-v vim' \
            --border-label=" enter switch · ctrl-k kill · ctrl-v open in vim · esc quit " \
            --border-label-pos=0:bottom \
            --preview='
                target=$(echo {} | sed "s/\x1b\[[0-9;]*m//g" | awk "{print \$1}")
                '"$CTX_BIN"' "$target" 2>/dev/null
            ' \
            --preview-window=right:50% \
            --bind="ctrl-s:change-prompt(session ❯ )+reload($0 _sessions)" \
            --bind="ctrl-w:change-prompt(window ❯ )+reload($0 _windows)" \
            --bind="ctrl-p:change-prompt(❯ )+reload($0 _panes)" \
            --bind="ctrl-k:execute-silent(tmux kill-pane -t \$(echo {} | sed 's/\x1b\[[0-9;]*m//g' | awk '{print \$1}') 2>/dev/null)+reload($0 _panes)" \
            --bind="ctrl-v:execute(target=\$(echo {} | sed 's/\x1b\[[0-9;]*m//g' | awk '{print \$1}'); $MD_BIN \"\$target\")" \
            --bind="shift-up:preview-up,shift-down:preview-down" \
            --bind="shift-left:preview-page-up,shift-right:preview-page-down" \
            --bind="ctrl-r:reload($0 _panes)")

    [[ -z "$choice" ]] && exit 0

    local target
    target=$(echo "$choice" | sed 's/\x1b\[[0-9;]*m//g' | awk '{print $1}')
    [[ -z "$target" ]] && exit 0

    # Switch to the target (works for session, session:window, or session:window.pane)
    if [[ "$target" == *"."* ]]; then
        tmux select-pane -t "$target" 2>/dev/null
        tmux select-window -t "${target%.*}" 2>/dev/null
        tmux switch-client -t "${target%%:*}" 2>/dev/null || true
    elif [[ "$target" == *":"* ]]; then
        tmux select-window -t "$target" 2>/dev/null
        tmux switch-client -t "${target%%:*}" 2>/dev/null || true
    else
        tmux switch-client -t "$target" 2>/dev/null || true
    fi
}

# ─── Dispatch ────────────────────────────────────────────────────────────────

case "${1:-nav}" in
    nav|menu|switch|panes|sessions)
        do_navigate ;;
    _sessions)
        _list_sessions ;;
    _windows)
        _list_windows ;;
    _panes)
        _list_panes ;;
    *)
        echo "Usage: tmux-mgr-fzf [nav|_sessions|_windows|_panes]"
        exit 1 ;;
esac
